# Copy to .env and fill in values (never commit .env)
#
# Docker:
#   Dev:  docker compose up --build
#   Prod: docker compose -f docker-compose.prod.yml up --build -d
#         (set CORS_ORIGIN=http://localhost:8080 unless you use another public URL)

# Mongo image (Compose). If pulls fail with TLS timeout, keep default mirror or set your mirror:
# MONGO_IMAGE=mongo:7
MONGODB_URI=mongodb://mongo:27017/professorx

# API
PORT=4000
NODE_ENV=development
JWT_SECRET=change-me-to-a-long-random-string
# Dev (Vite): http://localhost:5173 | Prod compose (nginx on 8080): http://localhost:8080
CORS_ORIGIN=http://localhost:5173

# Google Gemini — key stays server-side only
# Default model: stable, fast, low cost. Override for newer preview:
#   GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Web (Vite) — browser calls API (dev only; prod build uses same-origin nginx proxy)
VITE_API_URL=http://localhost:4000
